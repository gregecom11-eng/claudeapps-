# Browser-safe (these are exposed in the bundle, that's fine)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only — set on Cloudflare Pages → Settings → Environment variables
# Used by /api/* and /mcp Functions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Static API key used by the Claude.ai Custom Connector to call /mcp.
# Generate any random string (32+ chars). Save it; you'll paste it into
# Claude when adding the connector.
MCP_API_KEY=

# Anthropic key for AI-generated ride packets, briefings, invoices.
# Optional — leave blank to disable AI features.
ANTHROPIC_API_KEY=

# Optional — model override
ANTHROPIC_MODEL=claude-sonnet-4-6
