# Server-side only — never expose to the browser.
# Used by Cloudflare Pages Functions at /api/agent/*

# OpenAI credentials
OPENAI_API_KEY=
OPENAI_PROJECT_ID=

# Optional: an Assistant or Custom-GPT/Agent identifier. Used as context
# for the Responses API call. Leave empty if you only want a plain chat.
OPENAI_AGENT_ID=

# Optional model override (defaults to gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Optional: GitHub Personal Access Token with `gist` scope, used by the
# server proxy to read/write a private gist for cross-device sync.
GITHUB_GIST_TOKEN=

# Optional: pre-existing private gist id to sync into. If empty, the app
# will create one on first sync and store the id back into local state.
GITHUB_GIST_ID=
